<Window x:Class="BMSSoftware.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BMSSoftware"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        Title="MainWindow" Height="700" Width="1200"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid Background="#0A0C22">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock Text="CALB-BMS监控软件" 
                       Foreground="White" 
                       FontFamily="fonts/#iconfont"
                       FontSize="20" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Left"
                       Margin="20 15 15 15"
                       Width="154">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#7EFFFF"  
                                      Direction="0" 
                                      ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>

            <Button Style="{StaticResource ButtonStyle}"
                    Content="读取DBC"
                    Margin="-720 0 0 0"
                    Command="{Binding ReadDBCCommand}"/>
            
            <Button Style="{StaticResource ButtonStyle}"
                    Content="连接设置"
                    Margin="-488 0 0 0"
                    Command="{Binding OpenConnectPageCommand}"
                              />

            <Button Style="{StaticResource ButtonStyle}"
                    Content="{Binding ReceivtState}"
                    Margin="-260 0 0 0"
                    Command="{Binding ReceiveDatasCommand}"/>

            <TextBlock Text="BMS状态:" 
                       Margin="-70 0 0 0"
                       Foreground="#4B8EC4"
                       FontSize="15"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>

            <Ellipse Width="30"
                     Height="30"
                     Margin="45 0 0 0"
                     Fill="{Binding BMSState}"/>

            <ToggleButton x:Name="LangToggle"
                      Style="{StaticResource LanguageToggleStyle}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Checked="LangToggle_Checked"
                          Margin="250 0 0 0"
                      Unchecked="LangToggle_Checked"
                          />

            <Button x:Name="CloseApp"
                Style="{StaticResource ExitApp}"
                    Click="CloseApp_Click"/>
        </Grid>
        
        <Frame Grid.Row="1" 
               Content="{Binding CurrentPage}"
               NavigationUIVisibility="Hidden"
               BorderThickness="0"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal">

            <Menu Style="{StaticResource MechanicalMenuStyle}"
                  Width="100" Height="45" Margin="10 0 0 0"
                  >
                <MenuItem Header="项目选择" Height="45"
                          Width="100"
                           Style="{StaticResource MechanicalMenuItemStyle}">
                    <MenuItem Header="储能" Style="{StaticResource MechanicalMenuItemStyle}" Width="100"
                              Command="{Binding ChooseProjectTypeCommand}"
                              CommandParameter="储能"/>
                </MenuItem>
            </Menu>

            <TextBlock Text="Can通讯状态:" 
                       Margin="10"
                       Foreground="#4B8EC4"
                       FontSize="15"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>

            <Ellipse Width="30"
                     Height="30"
                     Fill="{Binding CanState}"/>

            <TextBlock Text="硬件版本:"
                       Margin="10"
                       Foreground="#4B8EC4"
                       FontSize="15"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding HardWareVer}"
                       Margin="10"
                       Foreground="#4B8EC4"
                       FontSize="15"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="软件版本:"
                       Margin="10"
                       Foreground="#4B8EC4"
                       FontSize="15"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding SoftWareVer}"
                       Margin="10"
                       Foreground="#4B8EC4"
                       FontSize="15"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        
    </Grid>
</Window>
