<Window x:Class="BMSSoftware.Views.CommunityParamsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BMSSoftware.Views"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="CommunityParamsView" 
        Height="500" Width="500"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True">
    <Grid>
        <Border Background="#0A0C22" CornerRadius="30"
                BorderBrush="#C0F3F0" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="9*"/>
                </Grid.RowDefinitions>

                <Button Style="{StaticResource ExitApp}"
                        Click="Button_Click"/>
                <TextBlock Text="通讯设置" Foreground="White" 
                           FontSize="40" VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Width="300" Height="50"/>

                <TabControl Grid.Row="1" Style="{StaticResource NewTabControlStyle}"
                            Width="480" Height="430" Background="Transparent">
                    <TabItem Header="{DynamicResource CanConnect}" Style="{DynamicResource NewTabItemStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{DynamicResource CanDeviceType}" Foreground="White"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0 0 20 0"/>
                            <TextBlock Text="{DynamicResource CanDeviceIndex}" Foreground="White"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0 0 20 0" Grid.Row="1"/>
                            <TextBlock Text="{DynamicResource CanChannelIndex}" Foreground="White"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0 0 20 0" Grid.Row="2"/>
                            <TextBlock Text="{DynamicResource CanAcceptCode}" Foreground="White"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0 0 20 0" Grid.Row="3"/>
                            <TextBlock Text="{DynamicResource CanBlockCode}" Foreground="White"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0 0 20 0" Grid.Row="4"/>
                            <TextBlock Text="{DynamicResource CanTimer0}" Foreground="White"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0 0 20 0" Grid.Row="5"/>
                            <TextBlock Text="{DynamicResource CanTimer1}" Foreground="White"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0 0 20 0" Grid.Row="6"/>
                            <TextBlock Text="{DynamicResource CanFilterMode}" Foreground="White"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0 0 20 0" Grid.Row="7"/>

                            <!--ItemSource需要建立绑定，SelectedValue也需要传递给后台
                            可以定义一个选择事件，将选项内容以参数的方式传递后台-->
                            <ComboBox Style="{DynamicResource MechanicalComboBoxStyle2}"
                                  Width="180" HorizontalAlignment="Left" Margin="0 5"
                                  MaxDropDownHeight="200"
                                  Grid.Row="0"
                                      Grid.Column="1"
                                  ItemsSource="{Binding DeviceType}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="SelectionChanged">
                                        <i:InvokeCommandAction Command="{Binding DeviceTypeChangedCommand}"
                                   CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=ComboBox}}">
                                        </i:InvokeCommandAction>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </ComboBox>

                            <ComboBox Style="{DynamicResource MechanicalComboBoxStyle2}"
                                  Width="180" HorizontalAlignment="Left" Margin="0 5"
                                  MaxDropDownHeight="200"
                                  Grid.Row="1"
                                      Grid.Column="1"
                                      IsEnabled="{Binding DeviceIndexEnable}"
                                  ItemsSource="{Binding DeviceIndex}"
                                  SelectedValue="{Binding device_index_,UpdateSourceTrigger=PropertyChanged}">
                            </ComboBox>
                            <ComboBox Style="{DynamicResource MechanicalComboBoxStyle2}"
                                  Width="180" HorizontalAlignment="Left" Margin="0 5"
                                  MaxDropDownHeight="200"
                                  Grid.Row="2"
                                      Grid.Column="1"
                                  ItemsSource="{Binding CanIndex}"
                                      SelectedIndex="{Binding Channel_Index,UpdateSourceTrigger=PropertyChanged}">

                            </ComboBox>
                            <!--<ComboBox Style="{DynamicResource MechanicalComboBoxStyle2}"
                                  Width="180" HorizontalAlignment="Left" Margin="0 5"
                                  MaxDropDownHeight="200"
                                  Grid.Row="3"
                                      Grid.Column="1"
                                      IsEnabled="{Binding BaudrateEnable}"
                                  ItemsSource="{Binding BoudRate}"
                                  SelectedIndex="{Binding CurBoudRate,UpdateSourceTrigger=PropertyChanged}">
                            </ComboBox>-->
                            <TextBox Grid.Row="3" Grid.Column="1" Width="180" HorizontalAlignment="Left" Margin="0 4"
                                     Background="#FF2E2E2E" BorderBrush="#FF606060" CaretBrush="White"
                                     Foreground="White" Text="{Binding AccCode}"/>
                            <!--<ComboBox Style="{DynamicResource MechanicalComboBoxStyle2}"
                                  Width="180" HorizontalAlignment="Left" Margin="0 5"
                                  MaxDropDownHeight="200"
                                  Grid.Row="4"
                                      Grid.Column="1"
                                      IsEnabled="{Binding CanFDEnable}"
                                  SelectedIndex="{Binding Standard,UpdateSourceTrigger=PropertyChanged}">

                                <ComboBoxItem Content="CANFD ISO"/>
                                <ComboBoxItem Content="CANFD BOSCH"/>

                            </ComboBox>-->
                            <TextBox Grid.Row="4" Grid.Column="1" Width="180" HorizontalAlignment="Left" Margin="0 4"
         Background="#FF2E2E2E" BorderBrush="#FF606060" CaretBrush="White"
         Foreground="White" Text="{Binding AccMask}"/>
                            <!--<ComboBox Style="{DynamicResource MechanicalComboBoxStyle2}"
                                  Width="180" HorizontalAlignment="Left" Margin="0 5"
                                  MaxDropDownHeight="200"
                                  Grid.Row="5"
                                      Grid.Column="1"
                                      IsEnabled="{Binding CanFDEnable}"
                                      ItemsSource="{Binding ABITInfos}"
                                  SelectedIndex="{Binding CurABIT,UpdateSourceTrigger=PropertyChanged}">
                                
                            </ComboBox>-->
                            <TextBox Grid.Row="5" Grid.Column="1" Width="180" HorizontalAlignment="Left" Margin="0 4"
         Background="#FF2E2E2E" BorderBrush="#FF606060" CaretBrush="White"
         Foreground="White" Text="{Binding Timer0}"/>
                            <!--<ComboBox Style="{DynamicResource MechanicalComboBoxStyle2}"
                                  Width="180" HorizontalAlignment="Left" Margin="0 5"
                                  MaxDropDownHeight="200"
                                  Grid.Row="6"
                                      Grid.Column="1"
                                      IsEnabled="{Binding CanFDEnable}"
                                      ItemsSource="{Binding DBITInfos}"
                                  SelectedIndex="{Binding CurDBIT,UpdateSourceTrigger=PropertyChanged}">
                               
                            </ComboBox>-->
                            <TextBox Grid.Row="6" Grid.Column="1" Width="180" HorizontalAlignment="Left" Margin="0 4"
         Background="#FF2E2E2E" BorderBrush="#FF606060" CaretBrush="White"
         Foreground="White" Text="{Binding Timer1}"/>
                            <ComboBox Style="{DynamicResource MechanicalComboBoxStyle2}"
                                  Width="180" HorizontalAlignment="Left" Margin="0 5"
                                  MaxDropDownHeight="200"
                                  Grid.Row="7"
                                      Grid.Column="1"
                                      IsEnabled="{Binding StandardEnable}"
                                  SelectedIndex="{Binding Standard2,UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="接收全部类型"/>
                                <ComboBoxItem Content="只接收标准帧"/>
                                <ComboBoxItem Content="只接收扩展帧"/>
                            </ComboBox>

                            <TextBlock Grid.Row="8" HorizontalAlignment="Right" Margin="0 0 20 0"
                                        Foreground="White" VerticalAlignment="Center"
                                       Text="{DynamicResource CanMode}"/>
                            <ComboBox Style="{DynamicResource MechanicalComboBoxStyle2}"
      Width="180" HorizontalAlignment="Left" Margin="0 5"
      MaxDropDownHeight="200"
      Grid.Row="8"
          Grid.Column="1"
      SelectedIndex="{Binding Standard2,UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="正常"/>
                                <ComboBoxItem Content="只听"/>
                                <ComboBoxItem Content="自测"/>
                            </ComboBox>

                            <Button Grid.Row="9" Content="{DynamicResource btnCanConnect}"
                                    Style="{StaticResource IndustrialButtonStyle}"
                                    Width="100" FontSize="14" Padding="15 0"
                                    Margin="0 0 -95 0"
                                    Command="{Binding ConnectCanCommand}"
                                    CommandParameter="连接"/>

                            <Button Grid.Row="9"  Grid.Column="1" Content="{DynamicResource btnCanDisConnect}"
                                    Style="{StaticResource IndustrialButtonStyle}"
                                    Width="100" FontSize="14" Padding="15 0"
                                    Foreground="#D05C5C"
                                    Margin="-135 0 0 0"
                                    Command="{Binding ConnectCanCommand}"
                                    CommandParameter="断开"/>
                        </Grid>
                        
                    </TabItem>

                    <TabItem Header="串口通讯" Style="{DynamicResource NewTabItemStyle}">

                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>
