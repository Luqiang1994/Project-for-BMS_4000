<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system ="clr-namespace:System;assembly=mscorlib">
    <!--CAN通讯设置-->
    <system:String x:Key="CanConnect">Can通讯</system:String>
    <system:String x:Key="CanDeviceType">设备类型:</system:String>
    <system:String x:Key="CanDeviceIndex">设备索引:</system:String>
    <system:String x:Key="CanChannelIndex">通道号:</system:String>
    <system:String x:Key="CanAcceptCode">验收码:0x</system:String>
    <system:String x:Key="CanBlockCode">屏蔽码:0x</system:String>
    <system:String x:Key="CanTimer0">定时器0:0x</system:String>
